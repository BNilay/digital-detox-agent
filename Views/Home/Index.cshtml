@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-5">
    <div class="row align-items-center mb-5 pt-4">
        <div class="col-lg-6 text-center text-lg-start mb-4 mb-lg-0">
            <span class="badge bg-success bg-opacity-10 text-success mb-3 px-3 py-2 rounded-pill">Daha Sağlıklı Bir Dijital Yaşam</span>
            <h1 class="display-4 fw-bold text-dark mb-3">AI Destekli <br /><span class="text-success">Dijital Bağımlılık Azaltma Sistemi</span></h1>
            <p class="lead text-muted mb-4">
                Bu sistem, günlük ekran sürenizi analiz ederek size özel azaltma planı ve öneriler üretir. Telefon bağımlılığını azaltmak için yapay zeka asistanınız yanınızda.
            </p>
            <div class="d-flex justify-content-center justify-content-lg-start gap-3">
                <a asp-controller="User" asp-action="Create" class="btn btn-success btn-lg px-4 shadow-sm">
                    <i class="fa-solid fa-user-plus me-2"></i> Profilini Oluştur ve Başla
                </a>
            </div>
        </div>
        <div class="col-lg-6 text-center">
            <div class="p-5 bg-success bg-opacity-10 rounded-circle d-inline-block shadow-sm" style="backdrop-filter: blur(5px);">
                <i class="fa-solid fa-mobile-screen-button text-success" style="font-size: 12rem;"></i>
            </div>
        </div>
    </div>

    <hr class="text-muted opacity-25 my-5" />

    <div class="row text-center mt-5 pb-5">
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 transition-hover bg-white bg-opacity-75" style="backdrop-filter: blur(8px);">
                <div class="card-body p-4">
                    <div class="bg-success bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 64px; height: 64px;">
                        <i class="fa-solid fa-chart-pie fa-xl"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark">Kullanım Analizi</h3>
                    <p class="text-muted">Hangi uygulamada ne kadar vakit geçirdiğinizi detaylı olarak görün ve kendi sınırlarınızı belirleyin.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 transition-hover bg-white bg-opacity-75" style="backdrop-filter: blur(8px);">
                <div class="card-body p-4">
                    <div class="bg-success bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 64px; height: 64px;">
                        <i class="fa-solid fa-robot fa-xl"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark">Yapay Zeka Koçu</h3>
                    <p class="text-muted">Size özel dijital detoks planları oluşturan ve motivasyon sağlayan akıllı sistem ile tanışın.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 transition-hover bg-white bg-opacity-75" style="backdrop-filter: blur(8px);">
                <div class="card-body p-4">
                    <div class="bg-success bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 64px; height: 64px;">
                        <i class="fa-solid fa-leaf fa-xl"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark">Zihinsel Rahatlama</h3>
                    <p class="text-muted">Sürekli gelen bildirimlerden uzak, odaklanmış ve çok daha huzurlu bir yaşam tarzına adım atın.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }
</style>